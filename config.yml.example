# Misha Code Server session configuration
# These match the Open OnDemand Code Server form fields.
#
# Copy this file to config.yml and fill in your values:
#   cp config.yml.example config.yml

netid: your_netid
working_directory: /gpfs/radev/home/your_netid/your_project
hours: 2
cpus_per_task: 1
memory_per_cpu_gib: 32
partition: devel
reservation:          # optional
custom_command:       # optional
additional_modules:   # optional, space-separated module names
